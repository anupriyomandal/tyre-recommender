# OpenAI API key (required for embeddings and LLM responses)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram bot token from @BotFather (required for telegram_bot.py)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Full URL to the deployed /ask endpoint (required for telegram_bot.py)
# Example: https://tyre-api-production.up.railway.app/ask
API_URL=https://your-railway-url/ask
